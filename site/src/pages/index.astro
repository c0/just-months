---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../../public/hero.png";
import screenshotNotificationCenter from "../../public/screenshot-notification-center.png";
import screenshotDesktop from "../../public/screenshot-desktop.png";

const APP_VERSION = "1.0.3"; // ← release skill updates this line on each release
const DMG_URL = `https://github.com/c0/just-months/releases/download/v${APP_VERSION}/JustMonths-${APP_VERSION}.dmg`;
const GITHUB_URL = "https://github.com/c0/just-months";

const FEATURES = [
  "View 4-6 months at a time without clicking arrows!",
  "Tap the widget to open Google Calendar, Apple Calendar, or Outlook",
  "Put on your desktop or in the Notification Center",
  "macOS 14 Sonoma and later",
];
---

<Layout>
  <main>
    <div class="hero">
      <Image src={heroImage} alt="Just Months" class="hero-image" />
      <h1>Just Months</h1>
      <p class="tagline">A monthly calendar and no extras.</p>
      <p class="description">
        Free app that shows multiple months at one time.
      </p>
      <div class="buttons">
        <a href={DMG_URL} class="btn primary"
          ><svg
            width="16"
            height="16"
            viewBox="0 0 814 1000"
            fill="currentColor"
            ><path
              d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57.8-155.5-127.4c-58.5-81.7-105.3-209-105.3-329.1 0-193.1 125.6-295.7 249.2-295.7 65.7 0 120.5 43.2 161.7 43.2 39.2 0 100.4-45.8 174.5-45.8 28.2 0 129.3 2.6 196.3 99.8zm-135.5-183.1c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.2 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
            ></path></svg
          > Download for macOS</a
        >
        <a href={GITHUB_URL} class="btn secondary">GitHub</a>
      </div>
      <p class="requires">{APP_VERSION} &middot; macOS Sonoma or later</p>
    </div>

    <section class="features">
      <h2>features</h2>
      <ul>
        {FEATURES.map((f) => <li>{f}</li>)}
      </ul>
    </section>
    <section class="screenshots">
      <Image src={screenshotNotificationCenter} alt="" class="screenshot" />
      <Image src={screenshotDesktop} alt="" class="screenshot" />
    </section>
    <footer>
      <p>
        &copy; 2026 &middot; <a href={GITHUB_URL}>Open source</a> under MIT
      </p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 80px 24px 60px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    justify-content: center;
  }

  .hero-image {
    width: 480px;
    height: 480px;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1rem;
    color: var(--text-tertiary);
    max-width: 420px;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .buttons {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .btn {
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: opacity 0.15s;
    text-decoration: none;
  }

  .btn:hover {
    opacity: 0.85;
  }

  .btn.primary {
    background: var(--gradient);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid #1c284a;
  }

  .btn.primary svg {
    flex-shrink: 0;
  }

  .btn.secondary {
    background: var(--text);
    color: var(--bg);
  }

  .requires {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  .screenshots {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .screenshot {
    width: 100%;
    height: auto;
    max-width: 800px;
    display: block;
  }

  @media (max-width: 600px) {
    .screenshot {
      max-width: 100%;
    }
  }

  footer {
    padding: 2rem;
    font-size: 0.8rem;
    color: var(--text-tertiary);
    text-align: center;
  }

  footer a {
    text-decoration: underline;
    text-underline-offset: 2px;
    color: var(--text);
  }
</style>
